@@ -0,0 +1,61 @@
+<?php
+
+declare(strict_types=1);
+
+namespace Drupal\Tests\node\Kernel;
+
+use Drupal\Core\Config\Config;
+use Drupal\KernelTests\KernelTestBase;
+use PHPUnit\Framework\Attributes\Group;
+use PHPUnit\Framework\Attributes\RunTestsInSeparateProcesses;
+
+/**
+ * Tests node post update functions.
+ */
+#[Group('node')]
+#[RunTestsInSeparateProcesses]
+class NodePostUpdateTest extends KernelTestBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  protected static $modules = ['field', 'filter', 'node', 'system', 'text', 'user', 'views'];
+
+  /**
+   * The content View pager heading level config path.
+   */
+  private const PAGER_HEADING_LEVEL = 'display.default.display_options.pager.options.pagination_heading_level';
+
+  /**
+   * {@inheritdoc}
+   */
+  protected function setUp(): void {
+    parent::setUp();
+    $this->installEntitySchema('user');
+    $this->installConfig(['node']);
+    require_once $this->root . '/core/modules/node/node.post_update.php';
+  }
+
+  /**
+   * Tests content View pager heading level updates.
+   */
+  public function testContentViewPagerHeadingLevelPostUpdate(): void {
+    $this->assertSame('h2', $this->contentViewConfig()->get(self::PAGER_HEADING_LEVEL));
+
+    $this->contentViewConfig()->set(self::PAGER_HEADING_LEVEL, 'h4')->save();
+    node_post_update_content_view_pager_heading_level();
+    $this->assertSame('h2', $this->contentViewConfig()->get(self::PAGER_HEADING_LEVEL));
+
+    $this->contentViewConfig()->set(self::PAGER_HEADING_LEVEL, 'h3')->save();
+    node_post_update_content_view_pager_heading_level();
+    $this->assertSame('h3', $this->contentViewConfig()->get(self::PAGER_HEADING_LEVEL));
+  }
+
+  /**
+   * Gets the editable content View configuration.
+   */
+  private function contentViewConfig(): Config {
+    return $this->container->get('config.factory')->getEditable('views.view.content');
+  }
+
+}
